# Copy this file to android/keystore.properties and fill in your values.
# The real keystore.properties is gitignored — NEVER commit it.
#
# Generate the .jks once with:
#   keytool -genkey -v -keystore krator-rewards-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias krator-upload
#
# Put the .jks file at android/keystore/krator-rewards-release.jks
# (the android/keystore folder is gitignored).

storeFile=keystore/krator-rewards-release.jks
storePassword=CHANGE_ME
keyAlias=krator-upload
keyPassword=CHANGE_ME
